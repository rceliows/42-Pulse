# ============================================================================ #
#  .env.example - 42 API / OAuth secrets
#
#  Copy this to /srv/42_Network/.env (i.e. one directory above this repo
#  checkout) and fill in the values from your 42 application:
#  https://profile.intra.42.fr/oauth/applications
#
#  Do NOT put ACCESS_TOKEN or REFRESH_TOKEN here; tokens are stored only in
#  repo/.oauth_state after running `make exchange`.
#
#  Runtime/deploy settings (DB_*, CAMPUS_ID, WEB_PORT, etc.) belong in
#  transcendance.config, not here - see transcendance.config.example.
# ============================================================================ #

CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI=
SCOPE=public
