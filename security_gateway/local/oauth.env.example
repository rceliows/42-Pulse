# Copy this file to local/oauth.env and fill the 42 OAuth application values.
# Never commit local/oauth.env.

PUBLIC_BASE_URL=https://localhost:9443
UPSTREAM_URL=http://web:80

# Optional. If empty, `make seed` generates one directly in Vault.
SESSION_SECRET=

# 42 OAuth application values from https://profile.intra.42.fr/oauth/applications
OAUTH_42_CLIENT_ID=
OAUTH_42_CLIENT_SECRET=
OAUTH_42_SCOPES=public
