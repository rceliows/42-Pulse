# ============================================================================ #
#  transcendance.config.example - Runtime/deployment configuration
#
#  Copy this to /srv/42_Network/transcendance.config:
#    cp repo/transcendance.config.example ../transcendance.config
#
#  Keep API/OAuth secrets in ../.env only.
# ============================================================================ #

# Runtime/deployment settings (non-API secrets)
# Keep OAuth/API credentials in /srv/42_Network/.env

# Optional: repo root.
# If omitted, deploy uses the directory where make is launched.
# ROOT_DIR=repo

# Core deploy
CAMPUS_ID=...
WEB_PORT=...

# Optional: override Docker socket group GID.
# If omitted, make deploy uses /var/run/docker.sock automatically.
# DOCKER_GID=...

# Database
DB_HOST=...
DB_PORT=...
DB_NAME=...
DB_USER=...
DB_PASSWORD=...
DB_DATA_DIR=../data/postgres

# Grafana admin credentials (used by the grafana service in infra/docker-compose.yml)
# GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=...

# Comma-separated list of origins allowed to make cross-origin requests to the API
# (with credentials). Defaults to common localhost dev origins if omitted.
# FRONTEND_ORIGIN=https://pulse.example.com

# Runtime/ops tuning (non-secret)
USER_DATA_STALE_AFTER_S=600
AUTO_MAINTENANCE_INTERVAL_S=3600
AUTO_MAINTENANCE_REMOVE_ORPHANS=0
ADMIN_API42_HEALTH_CACHE_S=300
HEALTH_WARN_FETCH_QUEUE_INTERNAL_MAX=200
HEALTH_DEGRADED_FETCH_QUEUE_EXTERNAL_MAX=1000
HEALTH_DEGRADED_PROCESS_QUEUE_MAX=200
BACKUP_RETENTION_DAYS=14

# Optional: force compose runtime uid/gid (default is current host user/group)
# HOST_UID=...
# HOST_GID=....
